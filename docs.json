{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "BuildingSwell API",
  "description": "Integrate with the BuildingSwell v2 Public API",
  "logo": {
    "light": "/images/logo/light.svg",
    "dark": "/images/logo/dark.svg",
    "href": "https://www.buildingswell.com"
  },
  "favicon": "/images/logo/light.svg",
  "colors": {
    "primary": "#469CD0",
    "light": "#E3E4EB",
    "dark": "#2B6F94"
  },
  "navbar": {
    "links": [
      {
        "label": "App",
        "href": "https://app.buildingswell.com"
      },
      {
        "label": "Support",
        "href": "https://www.buildingswell.com/support"
      }
    ]
  },
  "api": {
    "openapi": "openapi.yaml",
    "mdx": {
      "server": "https://app.buildingswell.com/api/v2",
      "auth": {
        "method": "key",
        "name": "X-API-Key"
      }
    },
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": ["bash", "javascript", "python"],
      "defaults": "all",
      "autogenerate": true
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "pages": [
              "index",
              "getting-started/authentication",
              "getting-started/rate-limits"
            ]
          },
          {
            "group": "Core concepts",
            "icon": "layers",
            "pages": [
              "guides/standard-endpoints",
              "guides/querying",
              "guides/response-format",
              "guides/group-and-count",
              "guides/import-export"
            ]
          },
          {
            "group": "Resources",
            "icon": "database",
            "pages": [
              "resources/project",
              "resources/stage",
              "resources/deliverable",
              "resources/deliverable-dependencies",
              "resources/deliverable-work-sessions",
              "resources/comment",
              "resources/document",
              "resources/note",
              "resources/notification",
              "resources/qc-inspection-set",
              "resources/qc-template",
              "resources/timesheet",
              "resources/worker",
              "resources/role",
              "resources/organization-member",
              "resources/api-key"
            ]
          },
          {
            "group": "Domain concepts",
            "icon": "git-branch",
            "pages": ["concepts/overview"]
          },
          {
            "group": "Examples",
            "icon": "terminal",
            "pages": ["examples"]
          }
        ]
      },
      {
        "tab": "API reference",
        "icon": "square-terminal",
        "groups": [
